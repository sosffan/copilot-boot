{
  "id": "githubcopilot",
  "displayName": "GitHub Copilot",
  "mappings": [
    {
      "name": "Custom Instruction",
      "sourceDir": "rules",
      "destPattern": ".github/${basename}.instruction.md"
    },
    {
      "name": "Skills",
      "sourceDir": "skills",
      "destDir": ".github/skills"
    }
  ]
}