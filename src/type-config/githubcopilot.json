{
  "id": "githubcopilot",
  "displayName": "GitHub Copilot",
  "root": ".github",
  "mappings": [
    {
      "name": "Rules (instruction files)",
      "sourceDir": "rules",
      "destPattern": "./${basename}.instruction.md"
    },
    {
      "name": "Prompts",
      "sourceDir": "prompts",
      "destDir": "prompts"
    },
    {
      "name": "Skills",
      "sourceDir": "skills",
      "destDir": "skills"
    }
  ]
}